{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "watchNamespaces": {
      "type": "array",
      "description": "Namespaces watched by the operator. Empty means all namespaces.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    }
  }
}
